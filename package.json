{
  "name": "yandex-music-service",
  "version": "1.0.0",
  "description": "Modern music streaming service with Yandex Music integration",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:frontend",
    "build:frontend": "cd frontend && npm run build",
    "start": "cd backend && npm start",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "setup": "npm run install:all && echo 'Setup complete! Please configure your .env files.'"
  },
  "keywords": [
    "music",
    "streaming",
    "yandex-music",
    "react",
    "nodejs",
    "supabase"
  ],
  "author": "Music Service Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/yandex-music-service.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/yandex-music-service/issues"
  },
  "homepage": "https://github.com/your-username/yandex-music-service#readme"
}